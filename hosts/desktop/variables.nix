# =============================================================================
# Desktop Shared Variables / デスクトップ共通変数
# configuration.nix・home.nix・flake.nix の全モジュールで参照される
# 設定値をここで一元管理する
# =============================================================================

{
  # ---------------------------------------------------------------------------
  # User Account / ユーザーアカウント
  # ---------------------------------------------------------------------------
  # Linuxシステムアカウント名・ホームディレクトリ名（/home/<username>）
  username        = "xqtdk";
  # GECOSフィールド（ログイン画面等に表示される表示名）
  userDisplayName = "Tsudzuki";

  # ---------------------------------------------------------------------------
  # Desktop Environment / デスクトップ環境
  # ---------------------------------------------------------------------------
  enableGnome = true;
  enableKde   = true;
  enableNiri  = true;

  # ---------------------------------------------------------------------------
  # Input Method / 入力メソッド
  # ---------------------------------------------------------------------------
  enableMozc   = true;
  fcitx5Layout = "us";
}
