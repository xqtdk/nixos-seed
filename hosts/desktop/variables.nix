# =============================================================================
# Desktop Shared Variables / デスクトップ共通変数
# configuration.nix と home.nix の両方で参照される設定値をここで一元管理する
# =============================================================================

{
  # ---------------------------------------------------------------------------
  # Desktop Environment / デスクトップ環境
  # ---------------------------------------------------------------------------
  enableGnome = true;
  enableKde   = true;
  enableNiri  = true;

  # ---------------------------------------------------------------------------
  # Input Method / 入力メソッド
  # ---------------------------------------------------------------------------
  enableMozc   = true;
  fcitx5Layout = "us";
}
